---
interface Props {
  categories: string[];
  statuses: string[];
}

const { categories, statuses } = Astro.props as Props;
---

<div class="mt-6 grid gap-3 sm:grid-cols-2">
  <!-- Filtro de Categorías -->
  <details class="group rounded-xl border border-border bg-card px-4 py-3" open>
    <summary
      class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold text-foreground"
    >
      <span>Categorías</span>
      <span
        class="text-muted-foreground transition-transform duration-200 group-open:rotate-180"
        aria-hidden="true"
      >
        ▼
      </span>
    </summary>
    <div class="mt-3 flex flex-wrap gap-2" data-catalog-filter-group="category">
      {
        categories.map((category) => (
          <label class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-primary/5 hover:border-primary">
            <input
              type="checkbox"
              value={category}
              class="sr-only"
              data-catalog-category
            />
            <span>{category}</span>
          </label>
        ))
      }
    </div>
  </details>

  <!-- Filtro de Estado -->
  <details class="group rounded-xl border border-border bg-card px-4 py-3">
    <summary
      class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold text-foreground"
    >
      <span>Estado</span>
      <span
        class="text-muted-foreground transition-transform duration-200 group-open:rotate-180"
        aria-hidden="true"
      >
        ▼
      </span>
    </summary>
    <div class="mt-3 flex flex-wrap gap-2" data-catalog-filter-group="status">
      {
        statuses.map((status) => (
          <label class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-primary/5 hover:border-primary">
            <input
              type="checkbox"
              value={status}
              class="sr-only"
              data-catalog-status
            />
            <span>{status}</span>
          </label>
        ))
      }
    </div>
  </details>
</div>
