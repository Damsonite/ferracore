---
interface Props {
  productCount: number;
}

const { productCount } = Astro.props as Props;
---

<div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="text-sm font-medium uppercase tracking-[0.25em] text-primary">
      Catalogo
    </p>
    <h1
      class="mt-2 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
    >
      Productos para ferreteria
    </h1>
    <p
      class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground sm:text-base"
    >
      Usa el buscador para filtrar por nombre, categoria o descripcion.
    </p>
  </div>

  <p data-catalog-count class="text-sm font-medium text-muted-foreground">
    {productCount} productos
  </p>
</div>
