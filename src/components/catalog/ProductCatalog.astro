---
import SearchBar from "@/components/SearchBar.astro";
import { createServerSupabaseClient, supabase } from "@/db/supabase";
import type { Tables } from "../../types/database.types";

type Product = Tables<"products"> & {
  category?: { name: string } | null;
  status?: { name: string } | null;
  badge?: string | null;
};

const currencyFormatter = new Intl.NumberFormat("es-CO", {
  style: "currency",
  currency: "COP",
  maximumFractionDigits: 0,
});

const { data: products, error } = await supabase.from("products").select(
  `
      *,
      category:category_id (name),
      status:status_id (name)
    `,
);

const serverSupabase = createServerSupabaseClient();
const { data: categories, error: categoriesError } = await serverSupabase
  .from("categories")
  .select("name")
  .order("name", { ascending: true });

const categoryNames = (categories ?? [])
  .map((category) => category.name?.trim() ?? "")
  .filter(Boolean);
---

<div>
  {
    categoriesError && (
      <div
        role="alert"
        class="mb-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-900"
      >
        <strong>No se pudieron cargar las categorias.</strong>
        <div class="mt-1 text-sm">{categoriesError.message}</div>
      </div>
    )
  }
  <SearchBar categories={categoryNames} />
  {
    error ? (
      <div
        role="alert"
        class="p-4 rounded bg-red-50 border border-red-200 text-red-800"
      >
        <strong>Error loading products:</strong>
        <div class="mt-1 text-sm">{error.message ?? JSON.stringify(error)}</div>
      </div>
    ) : (products?.length ?? 0) === 0 ? (
      <div class="p-6 rounded bg-muted/50 border border-border text-muted-foreground">
        No products available yet.
      </div>
    ) : (
      <>
        <div
          data-no-results
          class="p-6 rounded bg-muted/50 border border-border text-muted-foreground"
          style="display:none"
        >
          No se encontraron productos.
        </div>

        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {products.map((product: Product) =>
            (() => {
              const productCategory = product.category?.name ?? "Sin categoría";
              const productBadge =
                product.badge ?? product.status?.name ?? "Disponible";

              return (
                <article
                  data-product-card
                  data-product-id={product.id}
                  data-product-name={product.name}
                  data-product-category={productCategory}
                  data-product-description={product.description}
                  data-product-badge={productBadge}
                  data-product-price={product.price}
                  data-product-stock={product.stock}
                  class="group rounded-3xl border border-border bg-card p-4 transition-transform duration-300 hover:-translate-y-0.5"
                >
                  <div class="overflow-hidden rounded-[1.25rem] border border-border bg-muted">
                    <div class="flex aspect-16/10 items-center justify-center bg-linear-to-br from-amber-100 via-stone-50 to-orange-50">
                      <div class="relative flex size-24 items-center justify-center rounded-3xl border border-border bg-background shadow-sm">
                        <div class="absolute inset-0 rounded-3xl bg-[radial-gradient(circle_at_top_left,rgba(217,119,6,0.18),transparent_55%),radial-gradient(circle_at_bottom_right,rgba(120,53,15,0.08),transparent_55%)]" />
                        <svg
                          aria-hidden="true"
                          viewBox="0 0 24 24"
                          fill="none"
                          class="relative z-10 size-10 text-primary"
                        >
                          <path
                            d="M4 16.5V7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5Z"
                            stroke="currentColor"
                            stroke-width="1.6"
                          />
                          <path
                            d="M7 15.5 10.2 12l2.4 2.7 1.5-1.5 3.9 4.8"
                            stroke="currentColor"
                            stroke-width="1.6"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                          <path
                            d="M10.2 9.4h.01"
                            stroke="currentColor"
                            stroke-width="2.2"
                            stroke-linecap="round"
                          />
                        </svg>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <span class="inline-flex items-center rounded-full border border-transparent bg-primary/10 px-2.5 py-1 text-xs font-medium leading-none text-primary">
                        {productBadge}
                      </span>
                      <h3 class="mt-2.5 text-lg font-semibold tracking-tight text-foreground">
                        {product.name}
                      </h3>
                      <p class="mt-1 text-sm text-muted-foreground">
                        {productCategory}
                      </p>
                    </div>

                    <div class="flex size-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                      <span class="text-lg font-semibold">FC</span>
                    </div>
                  </div>

                  <p class="mt-3 text-sm leading-6 text-muted-foreground">
                    {product.description}
                  </p>

                  <div class="mt-4 flex items-end justify-between border-t border-border pt-3">
                    <div>
                      <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
                        Precio
                      </p>
                      <p class="text-2xl font-semibold tracking-tight text-foreground">
                        {currencyFormatter.format(product.price)}
                      </p>
                    </div>

                    <div class="text-right text-sm text-muted-foreground">
                      <p>{product.stock} unidades</p>
                    </div>
                  </div>
                </article>
              );
            })(),
          )}
        </div>
      </>
    )
  }
</div>
