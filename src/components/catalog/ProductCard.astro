---
import { formatPrice } from "@/utils/formatters";

interface Props {
  id: string;
  name: string;
  description: string;
  price: number;
  stock: number;
  category: string;
  status: string;
  imageUrl?: string;
}

const { id, name, description, price, stock, category, status, imageUrl } =
  Astro.props;

const isOutOfStock = stock === 0;
---

<article
  data-product-card
  data-product-name={name}
  data-product-category={category}
  data-product-description={description}
  class="group rounded-2xl border border-border bg-card overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
>
  <!-- Imagen -->
  <a
    href={`/products/${id}`}
    class="block relative overflow-hidden bg-muted aspect-square"
  >
    {
      imageUrl ? (
        <img
          src={imageUrl}
          alt={name}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="flex items-center justify-center w-full h-full bg-linear-to-br from-amber-100 via-stone-50 to-orange-50">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            class="w-12 h-12 text-primary"
          >
            <path
              d="M4 16.5V7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5Z"
              stroke="currentColor"
              stroke-width="1.6"
            />
            <path
              d="M7 15.5 10.2 12l2.4 2.7 1.5-1.5 3.9 4.8"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M10.2 9.4h.01"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
            />
          </svg>
        </div>
      )
    }

    <!-- Stock badge -->
    {
      isOutOfStock && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/50">
          <span class="text-white font-semibold">Agotado</span>
        </div>
      )
    }
  </a>

  <!-- Contenido -->
  <div class="p-4">
    <!-- Badges -->
    <div class="flex gap-2 flex-wrap mb-3">
      <span
        class="inline-flex items-center rounded-full border border-transparent bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary"
      >
        {status}
      </span>
      {
        stock < 5 && stock > 0 && (
          <span class="inline-flex items-center rounded-full border border-orange-200 bg-orange-50 px-2.5 py-1 text-xs font-medium text-orange-700">
            Stock limitado
          </span>
        )
      }
    </div>

    <!-- Nombre y descripción -->
    <a href={`/products/${id}`} class="group/link">
      <h3
        class="font-semibold text-sm md:text-base leading-tight text-foreground group-hover/link:text-primary transition-colors line-clamp-2"
      >
        {name}
      </h3>
    </a>
    <p class="text-xs text-muted-foreground mt-1 line-clamp-2">{description}</p>

    <!-- Categoría -->
    <p class="text-xs text-muted-foreground mt-2">{category}</p>

    <!-- Footer: precio y botón -->
    <div
      class="flex items-center justify-between mt-4 pt-4 border-t border-border"
    >
      <span class="font-bold text-primary">{formatPrice(price)}</span>
      <a
        href={`/products/${id}`}
        class="inline-flex items-center justify-center rounded-lg bg-primary text-primary-foreground px-3 py-2 text-sm font-medium transition-colors hover:bg-primary/90 disabled:opacity-50 disabled:cursor-not-allowed"
        class:list={{ "opacity-50 cursor-not-allowed": isOutOfStock }}
      >
        Ver detalles
      </a>
    </div>
  </div>
</article>
