---
import AuthLayout from "@/layouts/AuthLayout.astro";
---

<AuthLayout
  title="Acceso admin | FerraCore"
  description="Inicia sesión para administrar el catálogo."
>
  <section
    class="rounded-[2rem] border border-border bg-card p-6 shadow-sm sm:p-8"
  >
    <div class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-primary">
        FerraCore Admin
      </p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-foreground">
        Iniciar sesión
      </h1>
      <p class="mt-3 text-sm leading-6 text-muted-foreground">
        Accede con tu cuenta de Supabase Auth para administrar productos e
        imágenes.
      </p>
    </div>

    <div
      id="auth-message"
      class="mb-4 hidden rounded-xl border px-4 py-3 text-sm"
      role="alert"
      aria-live="polite"
    >
    </div>

    <form id="login-form" class="space-y-4">
      <div class="form-group">
        <label class="form-label" for="email">Correo</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          minlength="8"
        />
      </div>

      <button
        type="submit"
        id="login-button"
        class="btn btn-primary btn-lg w-full"
      >
        Entrar al panel
      </button>
    </form>
  </section>

  <script type="module" src="/src/scripts/admin-login.ts"></script>
</AuthLayout>
