---
import { supabase } from "@/db/supabase";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { Tables } from "@/types/database.types";
import { formatPrice, formatStock } from "@/utils/formatters";

export const prerender = false;

type ProductDetail = Tables<"products"> & {
  category?: { id: string; name: string; slug: string } | null;
  status?: { id: string; name: string; slug: string } | null;
};

const productId = Astro.params.id;

if (!productId) {
  return Astro.redirect("/");
}

const parsedProductId = Number(productId);

if (!Number.isInteger(parsedProductId) || parsedProductId <= 0) {
  return Astro.redirect("/");
}

const { data: product, error } = await supabase
  .from("products")
  .select(
    `
      *,
      category:category_id (id, name, slug),
      status:status_id (id, name, slug)
    `,
  )
  .eq("id", parsedProductId)
  .eq("active", true)
  .maybeSingle<ProductDetail>();

if (error || !product) {
  return Astro.redirect("/");
}

const stockLabel = formatStock(product.stock);
const isOutOfStock = product.stock === 0;
const hasLowStock = product.stock > 0 && product.stock < 5;
const pageTitle = `${product.name} | FerraCore`;
const pageDescription = product.description
  ? product.description
  : "Detalle del producto en FerraCore.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container-main">
    <nav class="mb-6 text-sm text-muted-foreground" aria-label="Breadcrumb">
      <a href="/" class="hover:text-primary">Catálogo</a>
      <span class="mx-2">/</span>
      <span class="text-foreground">{product.name}</span>
    </nav>

    <div
      class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-start"
    >
      <section class="space-y-4">
        <div
          class="overflow-hidden rounded-4xl border border-border bg-card shadow-sm"
        >
          <div
            class="aspect-4/3 bg-linear-to-br from-amber-50 via-stone-50 to-orange-100 sm:aspect-16/10"
          >
            {
              product.image_url ? (
                <img
                  src={product.image_url}
                  alt={product.name}
                  class="h-full w-full object-cover"
                  loading="eager"
                />
              ) : (
                <div class="flex h-full items-center justify-center p-8">
                  <div class="max-w-sm rounded-[1.75rem] border border-border bg-background/90 p-8 text-center shadow-sm">
                    <div class="mx-auto flex size-20 items-center justify-center rounded-3xl bg-primary/10 text-primary">
                      <span class="text-3xl font-semibold">FC</span>
                    </div>
                    <p class="mt-4 text-lg font-semibold text-foreground">
                      Sin imagen disponible
                    </p>
                    <p class="mt-2 text-sm leading-6 text-muted-foreground">
                      Cuando se sube una imagen a Supabase Storage, aparecerá
                      aquí automáticamente.
                    </p>
                  </div>
                </div>
              )
            }
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-border bg-card p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
              Precio
            </p>
            <p class="mt-2 text-2xl font-semibold text-foreground">
              {formatPrice(product.price)}
            </p>
          </div>
          <div class="rounded-2xl border border-border bg-card p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
              Stock
            </p>
            <p class="mt-2 text-2xl font-semibold text-foreground">
              {product.stock}
            </p>
          </div>
          <div class="rounded-2xl border border-border bg-card p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
              Estado
            </p>
            <p
              class:list={[
                "mt-2 text-2xl font-semibold",
                isOutOfStock
                  ? "text-red-600"
                  : hasLowStock
                    ? "text-amber-600"
                    : "text-foreground",
              ]}
            >
              {stockLabel}
            </p>
          </div>
        </div>
      </section>

      <aside
        class="lg:sticky lg:top-24 h-fit space-y-4 rounded-4xl border border-border bg-card p-6 shadow-sm"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-[0.25em] text-primary"
            >
              Detalle del producto
            </p>
            <h1
              class="mt-2 text-3xl font-semibold tracking-tight text-foreground text-balance"
            >
              {product.name}
            </h1>
          </div>

          <div
            class="rounded-2xl bg-primary/10 px-3 py-2 text-sm font-semibold text-primary"
          >
            FC
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <span
            class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
          >
            {product.category?.name ?? "Sin categoría"}
          </span>
          <span
            class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-xs font-medium text-foreground"
          >
            {product.status?.name ?? "Disponible"}
          </span>
          <span
            class:list={[
              "inline-flex items-center rounded-full px-3 py-1 text-xs font-medium",
              isOutOfStock
                ? "bg-red-50 text-red-700"
                : hasLowStock
                  ? "bg-amber-50 text-amber-700"
                  : "bg-emerald-50 text-emerald-700",
            ]}
          >
            {stockLabel}
          </span>
        </div>

        <p class="text-sm leading-7 text-muted-foreground">
          {
            product.description ??
              "Este producto todavía no tiene una descripción."
          }
        </p>

        <div class="rounded-2xl border border-border bg-muted/30 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
            Identificador
          </p>
          <p class="mt-2 wrap-break-word text-sm font-medium text-foreground">
            #{product.id}
          </p>
        </div>

        <a
          href="/"
          class="inline-flex w-full items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground hover:bg-primary/90"
        >
          Volver al catálogo
        </a>
      </aside>
    </div>
  </div>
</BaseLayout>
