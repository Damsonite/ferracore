{
  "name": "ferracore",
  "compatibility_date": "2026-05-20",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "e0d68964b8894378b84a4120e1db01bb",
    },
  ],
}
